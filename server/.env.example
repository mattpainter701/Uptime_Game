# EVE-NG Configuration
EVENG_HOST=192.168.1.100
EVENG_USERNAME=admin
EVENG_PASSWORD=eve
EVENG_PROTOCOL=https
EVENG_VERIFY_SSL=false

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis (optional, for session management)
REDIS_URL=redis://localhost:6379

# JWT Secret (for player authentication)
JWT_SECRET=your-super-secret-key-change-in-production

# Uptime Tracking
UPTIME_CHECK_INTERVAL=30
UPTIME_POINTS_PER_MINUTE=1
UPTIME_BONUS_THRESHOLD=99.0
UPTIME_BONUS_MULTIPLIER=1.5

# Penalties
DOWNTIME_PENALTY_PER_MINUTE=5
REPUTATION_LOSS_PER_INCIDENT=2

# Ticket Time Limits
ENFORCE_TIME_LIMITS=true

# EVE-NG Timeouts
EVENG_TIMEOUT=30
EVENG_CONSOLE_TIMEOUT=10
